:- Merging array(sorted){Two pointer approach}:-


#include<iostream>
using namespace std;
void merge(int arr1[],int n, int arr2[],int m, int arr3[]){
    int i=0,j=0,k=0;
    while(i<n && j<m){
        if(arr1[i]<arr2[j]){
            arr3[k]=arr1[i];
            i++;
            k++;
        }
        else{
            arr3[k]=arr2[j];
            j++;
            k++;
        }
    }
    while(i<n){
         arr3[k]=arr1[i];
            i++;
            k++;
    }
    while(j<m){
        arr3[k]=arr2[j];
            j++;
            k++;
    }
}
void print(int ans[],int n){
    for(int i=0;i<n;i++){
        cout<<ans[i]<<" "<<endl;
    }
}
int main(){
    int arr1[4]={1,3,5,7};
    int arr2[4]={2,4,6,8};
    int arr3[8];
    merge(arr1,4,arr2,4,arr3);
    cout<<"merge array is:"<<endl;
    print(arr3,8);
    return 0;
}

Moving zeros:-

#include<iostream>
using namespace std;
int main(){
    int arr[5]={4,0,5,0,2};
    int j=0;
    for(int i=0;i<5;i++){
        if(arr[i] != 0){
            swap(arr[i],arr[j]);
            j++;
        }
    }
    for(int i=0;i<5;i++){
        cout<<arr[i]<<" "<<endl;
    }
    return 0;
}

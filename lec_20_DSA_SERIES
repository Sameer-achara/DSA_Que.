reverse an array:-

#include<iostream>
using namespace std;
int main(){
    int a[5]={1,2,3,4,5};
    int n=sizeof(a)/sizeof(a[0]);
    for(int i=0;i<n/2;i++){ // reverse array
        swap(a[i], a[n-i-1]);
    }
    cout<<"Array after reverse"<<endl;
    for(int i=0;i<5;i++){
        cout<<a[i]<<endl;
    }
    return 0;
}


reverse in given indexing:-


#include<iostream>
using namespace std;
int main(){
    int pos;
    int a[8]={2,5,1,7,9,3,5,10};
    int n=sizeof(a)/sizeof(a[0]);
    cout<<"Enter the position"<<endl;
    cin>>pos;
    int start = pos+1;
    int end = n-1;
    while(start<end){
        swap(a[start],a[end]);
        start++;
        end--;
    }
    cout<<"Array after positional reverse"<<endl;
    for(int i=0;i<8;i++){
        cout<<a[i]<<endl;
    }
    return 0;
}



PRIORITY QUEUE

#include<iostream>
#include<queue>
using namespace std;
int main(){
    priority_queue<int> maxi;
    priority_queue<int,vector<int>,greater<int>> mini;
    cout<<"MAX QUEUE"<<endl;
    maxi.push(3);
    maxi.push(2);
    maxi.push(1);
    maxi.push(4);
    maxi.push(5);
    int n=maxi.size();
    for(int i=0;i<n;i++){
        cout<<maxi.top()<<" "<<endl;
        maxi.pop();
    }

    cout<<"MIN QUEUE"<<endl;
    mini.push(3);
    mini.push(2);
    mini.push(1);
    mini.push(4);
    mini.push(5);
    int m=mini.size();
    for(int i=0;i<m;i++){
        cout<<mini.top()<<" "<<endl;
        mini.pop();
    }

    return 0;
}


ARRAY STL

#include<iostream>
#include<array>
using namespace std;
int main(){
    array<int,4> a={1,2,3,4};
    int size=a.size();
    for(int i=0;i<size;i++){
        cout<<a[i]<<" "<<endl;
    }
    cout<<"element at index 3 is : "<<a.at(3)<<endl;
    cout<<"empty or not : "<<a.empty()<<endl;
    cout<<"first element : "<<a.front()<<endl;
    cout<<"last element : "<<a.back();
    return 0;
}


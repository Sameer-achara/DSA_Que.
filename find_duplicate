#include <iostream>
using namespace std;

// Bubble Sort function
void bubbleSort(int arr[], int n) {
    for(int i=0; i<n-1; i++) {
        for(int j=0; j<n-i-1; j++) {
            if(arr[j] > arr[j+1]) {
                swap(arr[j], arr[j+1]);
            }
        }
    }
}

// Find duplicate after sorting
int findDuplicate(int arr[], int n) {
    bubbleSort(arr, n); // sort array first
    for(int i=0; i<n-1; i++) {
        if(arr[i] == arr[i+1]) {
            return arr[i]; // duplicate found
        }
    }
    return -1; // no duplicate
}

int main() {
    int sam[7] = {1,2,2,4,1,3,4};
    cout << "Duplicate: " << findDuplicate(sam, 7) << endl;
    return 0;
}

DEQUE STL

#include<iostream>
#include<deque>
using namespace std;
int main(){
    deque<int> d;
    d.push_back(4);
    d.push_front(8);
    for(int i:d){
        cout<<i<<" "<<endl;
    }
    d.pop_front();
    for(int i:d){
        cout<<i<<" "<<endl;
    }

    d.push_front(5);
    d.push_back(6);

    for(int i:d){
        cout<<i<<" "<<endl;
    }

    cout<<"first element:"<<d.front()<<endl;
    cout<<"last element:"<<d.back()<<endl;
    cout<<"size:"<<d.size()<<endl;
    cout<<"element at index 2:"<<d.at(2)<<endl;
    cout<<"empty or not:"<<d.empty()<<endl;
    d.erase(d.begin(),d.begin()+2);
    cout<<"size after erase"<<endl;
    cout<<"size:"<<d.size()<<endl;
    return 0;
}


STL ALGORITHMS

#include<iostream>
#include<bits/stdc++.h>
using namespace std;
int main(){
    vector<int> v;
    v.push_back(3);
    v.push_back(5);
    v.push_back(5);
    v.push_back(7);
    v.push_back(9);

    cout<<"is 7 present or not: "<<binary_search(v.begin(),v.end(),7)<<endl;
    cout<<"lower bound / first occurrence: "<<lower_bound(v.begin(),v.end(),5)-v.begin()<<endl;
    cout<<"upper bound / last occurrence: "<<upper_bound(v.begin(),v.end(),5)-v.begin()<<endl;

    int a=9,b=7;
    cout<<"max of a,b: "<<max(a,b)<<endl;
    cout<<"min if a,b: "<<min(a,b)<<endl;
    swap(a,b);
    cout<<"swapping of both a,b: "<<a<<","<<b<<endl;

    string abcd="sameer";
    reverse(abcd.begin(),abcd.end());
    cout<<"Reverse string is: "<<abcd<<endl;

    rotate(v.begin(),v.begin()+1,v.end());
    cout<<"After rotate"<<endl;
    for(int i:v){
        cout<<i<<" "<<endl;
    }

    rotate(abcd.begin(),abcd.begin()+1,abcd.end());
    cout<<"After rotated string"<<endl;
    for(char c:abcd){
        cout<<c<<" ";
    }
    return 0;
}
